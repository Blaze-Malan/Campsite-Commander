<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#1A2E22"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Campsite commander"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="48dp"/>


    <TextView
        android:id="@+id/tvTotalItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Items Packed: 0"
        android:textColor="#E8F5E9"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#2E7D32"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnAddGear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Gear"
        android:textSize="18sp"
        android:padding="16dp"
        android:backgroundTint="#8D6E63"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnViewDetailed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Packed Gear"
        android:textSize="18sp"
        android:padding="16dp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF" />


</LinearLayout>